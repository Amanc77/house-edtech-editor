# MongoDB
MONGODB_URI=mongodb://localhost:27017/syncdocs

# Auth.js
AUTH_SECRET=your-auth-secret-min-32-chars-long-here
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Providers (at least one required for AI features)
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Socket (dev runs Socket.io on 3001; production uses port 3000)
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SyncDocs

# Footer profiles (customize for submission)
NEXT_PUBLIC_AUTHOR_NAME=Your Name
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourprofile

# Security
MAX_SYNC_PAYLOAD_BYTES=1048576
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
